generator client {
  provider = "prisma-client-js"
  output   = "../node_modules/.prisma/client"
}

datasource db {
  provider = "postgresql"
}

model Provider {
  id        Int      @id @default(autoincrement())
  name      String   @unique
  baseUrl   String   @map("base_url")
  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz

  providerProducts ProviderProduct[]

  @@map("providers")
}

model Product {
  id           Int      @id @default(autoincrement())
  canonicalKey String   @unique @map("canonical_key")
  name         String
  description  String?
  createdAt    DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt    DateTime @updatedAt @map("updated_at") @db.Timestamptz

  providerProducts ProviderProduct[]

  @@index([name])
  @@map("products")
}

model ProviderProduct {
  id                Int      @id @default(autoincrement())
  providerId        Int      @map("provider_id")
  productId         Int      @map("product_id")
  externalId        String   @map("external_id")
  price             Decimal  @db.Decimal(12, 2)
  currency          Currency
  availability      Boolean  @default(true)
  sourceLastUpdated DateTime? @map("source_last_updated") @db.Timestamptz
  fetchedAt         DateTime @map("fetched_at") @db.Timestamptz
  isStale           Boolean  @default(false) @map("is_stale")
  createdAt         DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt         DateTime @updatedAt @map("updated_at") @db.Timestamptz

  provider Provider                @relation(fields: [providerId], references: [id], onDelete: Restrict)
  product  Product                 @relation(fields: [productId], references: [id], onDelete: Restrict)
  history  ProviderProductHistory[]

  @@unique([providerId, externalId])
  @@index([productId])
  @@index([providerId])
  @@index([providerId, availability])
  @@index([providerId, isStale])
  @@index([price])
  @@index([fetchedAt])
  @@map("provider_products")
}

enum Currency {
  USD
  EUR
  GBP
}

enum ChangeType {
  INITIAL
  PRICE_CHANGE
  AVAILABILITY_CHANGE
  BOTH
}

model ProviderProductHistory {
  id                Int        @id @default(autoincrement())
  providerProductId Int        @map("provider_product_id")
  price             Decimal    @db.Decimal(12, 2)
  oldPrice          Decimal?   @db.Decimal(12, 2) @map("old_price")
  currency          Currency
  availability      Boolean
  oldAvailability   Boolean?   @map("old_availability")
  changeType        ChangeType @map("change_type")
  changedAt         DateTime   @default(now()) @map("changed_at") @db.Timestamptz

  providerProduct ProviderProduct @relation(fields: [providerProductId], references: [id], onDelete: Restrict)

  @@index([providerProductId, changedAt(sort: Desc)])
  @@index([changeType])
  @@index([changedAt])
  @@index([changedAt(sort: Desc), changeType]) // Composite index for findChanges query
  @@map("provider_product_history")
}
