# Server Configuration
NODE_ENV=development
PORT=3398

# Database (PostgreSQL)
DB_HOST=localhost
DB_PORT=5433
DB_USERNAME=postgres
DB_PASSWORD=Password123
DB_NAME=products-service

# Prisma (Prisma CLI needs this)
DATABASE_URL=postgresql://postgres:Password123@localhost:5433/products-service

# Security
ALLOWED_ORIGINS=                   # comma-separated origins, e.g. https://app.example.com,https://admin.example.com

# Swagger
SWAGGER_PATH=api/docs

# API key auth (required, sent via x-api-key header)
API_KEY=change-me

# Rate limiting (all tiers apply simultaneously)
THROTTLE_SHORT_TTL=1000        # 1 second window
THROTTLE_SHORT_LIMIT=10        # max 10 requests per second
THROTTLE_MEDIUM_TTL=60000      # 1 minute window
THROTTLE_MEDIUM_LIMIT=100      # max 100 requests per minute
THROTTLE_LONG_TTL=3600000      # 1 hour window
THROTTLE_LONG_LIMIT=1000       # max 1000 requests per hour

# Simulated providers
SIM_MUTATION_INTERVAL_MS=5000
SIM_FAILURE_RATE=0.1
SIM_MAX_DELAY_MS=800

# Provider adapters
PROVIDER_A_URL=http://localhost:3398/api/v1/sim/providers/a/products
PROVIDER_B_URL=http://localhost:3398/api/v1/sim/providers/b/items
PROVIDER_C_URL=http://localhost:3398/api/v1/sim/providers/c/catalog
PROVIDER_TIMEOUT_MS=3000
RETRY_COUNT=3
RETRY_BACKOFF_MS=500
FETCH_INTERVAL_MS=30000
STALE_THRESHOLD_MS=90000
